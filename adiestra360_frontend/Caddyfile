# Servidor estático de la PWA en Railway.
# Railway inyecta el puerto en $PORT.
:{$PORT}

root * dist
encode gzip zstd

# El service worker y el manifest NO deben cachearse en el navegador,
# así el cliente siempre detecta nuevas versiones del shell.
@nocache path /sw.js /registerSW.js /manifest.webmanifest
header @nocache Cache-Control "no-cache, no-store, must-revalidate"

# Assets con hash en el nombre (build de Vite): cache inmutable de larga vida.
@assets path /assets/*
header @assets Cache-Control "public, max-age=31536000, immutable"

# SPA: rutas de React Router caen a index.html.
try_files {path} /index.html
file_server
