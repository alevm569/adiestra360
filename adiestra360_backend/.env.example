# === Backend Adiestra360 — variables de entorno ===
# Copia este archivo a .env para desarrollo local. En Railway se definen
# como variables del servicio (no se sube ningún .env al repo).

# Django
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=False

# Hosts y CSRF (separados por coma, sin espacios).
# En Railway, RAILWAY_PUBLIC_DOMAIN se añade solo; aquí pon dominios extra si los hay.
ALLOWED_HOSTS=tu-backend.up.railway.app
CSRF_TRUSTED_ORIGINS=https://tu-backend.up.railway.app

# CORS: orígenes del frontend (la PWA). Separados por coma.
CORS_ALLOWED_ORIGINS=https://tu-frontend.up.railway.app

# Validación (Fase 5): emails con acceso al panel de métricas (/api/validation/
# metrics/). Separados por coma. El modelo de usuario no tiene is_staff, así que
# el panel se gobierna por esta allowlist.
VALIDATION_ADMIN_EMAILS=valery.villarruel569@gmail.com

# Redirección forzada a HTTPS (Railway ya sirve HTTPS). Ponlo en False solo si
# depuras detrás de un proxy que no reenvía X-Forwarded-Proto.
SECURE_SSL_REDIRECT=True

# Base de datos MySQL.
# En Railway, referencia el servicio MySQL así (en el panel de variables):
#   DB_NAME     = ${{ MySQL.MYSQLDATABASE }}
#   DB_USER     = ${{ MySQL.MYSQLUSER }}
#   DB_PASSWORD = ${{ MySQL.MYSQLPASSWORD }}
#   DB_HOST     = ${{ MySQL.MYSQLHOST }}
#   DB_PORT     = ${{ MySQL.MYSQLPORT }}
DB_NAME=adiestra360
DB_USER=root
DB_PASSWORD=cambia-esto
DB_HOST=127.0.0.1
DB_PORT=3306
